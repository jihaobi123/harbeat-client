# 复制为 cypher.env 后填写真值，勿提交 cypher.env 到 Git
CYPHER_HOME=/home/cat/cypher
CYPHER_AUDIO_DEVICE=pulse
INPUT_DEVICE_PATH=/dev/input/by-id/usb-MYKB_E9s_vial:f64c2b3c-event-kbd
EDGE_AGENT_URL=http://127.0.0.1:9000
# Jetson Tailscale IP (真实生产环境)
JETSON_BASE_URL=http://100.87.142.21:8000
# 云网关入口（App 远程访问时走这里）
# JETSON_BASE_URL=http://8.136.120.255
# RK 设备 ID（需与云网关 RK_REGISTRY 一致）
RK_ID=rk-001
# JWT Token（从 App 登录后获取）
JWT_TOKEN=
# 可选的额外 RK Token
HARBEAT_RK_TOKEN=
EVENT_FLUSH_INTERVAL_SEC=5
EVENT_FLUSH_BATCH_SIZE=50
CYPHER_REQUIRE_STEMS_FOR_PLAY=0
