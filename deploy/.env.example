# HarBeat Production Configuration
APP_NAME=Street Dance MVP API
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000

# Database - provide the deployment database URL through the real .env file.
DATABASE_URL=postgresql+psycopg2://harbeat:<password>@<host>:5432/rhythm_prism

# Redis (docker internal)
REDIS_URL=redis://redis:6379/0

# JWT - CHANGE THIS!
JWT_SECRET=harbeat-prod-87780451-change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# File upload directory (inside container)
UPLOAD_DIR=/app/data/music-files
