# HarBeat Server Configuration
# Copy this file to .env and modify as needed

# Database (use local postgres in Docker, or remote)
DATABASE_URL=postgresql+psycopg2://harbeat:Hb12345678@postgres:5432/rhythm_prism

# Redis
REDIS_URL=redis://redis:6379/0

# JWT - CHANGE THIS in production!
JWT_SECRET=harbeat-production-secret-change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# File upload directory (inside container)
UPLOAD_DIR=/app/data/music-files
