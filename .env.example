APP_NAME=Street Dance MVP API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=postgresql+psycopg2://harbeat:<password>@<host>:5432/rhythm_prism
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me
JWT_ALGORITHM=HS256

# Optional metadata enrichment for library genre classification.
# Spotify provides artist/album microgenres; Discogs provides release genre/style tags.
SPOTIPY_CLIENT_ID=
SPOTIPY_CLIENT_SECRET=
DISCOGS_USER_TOKEN=
DISCOGS_USER_AGENT=HarBeat/1.0 +https://github.com/jihaobi123/harbeat-client

